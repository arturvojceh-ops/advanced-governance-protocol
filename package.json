{
  "name": "advanced-governance-protocol",
  "version": "1.0.0",
  "description": "Enterprise-grade decentralized governance system with quadratic voting and multi-tier delegation",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:goerli": "hardhat run scripts/deploy.js --network goerli",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "verify": "hardhat verify",
    "clean": "hardhat clean",
    "size": "hardhat size-contracts",
    "gas-report": "REPORT_GAS=true hardhat test",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol'",
    "docs": "hardhat docgen"
  },
  "keywords": [
    "governance",
    "dao",
    "quadratic-voting",
    "solidity",
    "ethereum",
    "defi",
    "smart-contracts",
    "delegation",
    "timelock",
    "analytics",
    "enterprise"
  ],
  "author": "Advanced Governance Protocol Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/advanced-governance-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/advanced-governance-protocol/issues"
  },
  "homepage": "https://github.com/your-username/advanced-governance-protocol#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^1.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/test-helpers": "^0.5.16",
    "@typechain/ethers-v6": "^0.4.0",
    "@typechain/hardhat": "^8.0.0",
    "chai": "^4.2.0",
    "ethers": "^6.4.0",
    "hardhat": "^2.17.0",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-docgen": "^1.3.0",
    "hardhat-gas-reporter": "^1.0.8",
    "prettier": "^2.8.4",
    "prettier-plugin-solidity": "^1.0.0",
    "solhint": "^3.3.7",
    "solidity-coverage": "^0.8.0",
    "typechain": "^8.3.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
